generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  secondmeUserId String?   @unique
  secondmeRoute  String?
  bio            String?
  accounts       Account[]
  sessions       Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Hero {
  id            String        @id @default(cuid())
  userId        String        @unique
  name          String
  avatar        String?
  route         String?
  mbti          String?
  sectId        String
  faction       String        @default("traditional")
  power         Int           @default(100)
  attack        Int           @default(100)
  speed         Int           @default(100)
  defense       Int           @default(100)
  reputation    Int           @default(1000)
  totalPower    Int           @default(400)
  winStreak     Int           @default(0)
  totalWins     Int           @default(0)
  totalBattles  Int           @default(0)
  title         String?
  points        Int           @default(0)
  lastLoginDate DateTime?
  loginStreak   Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sect          Sect          @relation(fields: [sectId], references: [id])
  ownedSkills   PlayerSkill[]
}

model Sect {
  id          String  @id @default(cuid())
  name        String  @unique
  type        String
  mbtiTypes   String
  location    String?
  source      String?
  bonus       String
  counter     String?
  weakTo      String?
  description String?
  heroes      Hero[]
}

model Battle {
  id              String   @id @default(cuid())
  challengerId    String
  opponentId      String
  winnerId        String?
  challengerSkill String?
  opponentSkill   String?
  rounds          Int      @default(0)
  challengerHp    Int      @default(100)
  opponentHp      Int      @default(100)
  pointsEarned    Int      @default(2)
  type            String   @default("friendly")
  createdAt       DateTime @default(now())
}

model PointTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  type        String
  description String
  balance     Int
  createdAt   DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  userName  String
  content   String
  type      String   @default("text")
  likes     Int      @default(0)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Gift {
  id          String  @id @default(cuid())
  name        String  @unique
  type        String
  price       Int
  effect      Int
  description String
  isLimited   Boolean @default(false)
}

model PlayerSkill {
  id          String   @id @default(cuid())
  userId      String
  skillName   String
  purchasedAt DateTime @default(now())
  hero        Hero     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, skillName])
}

model GiftTransaction {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  giftName   String
  message    String?
  createdAt  DateTime @default(now())
}

model Relationship {
  id        String   @id @default(cuid())
  userId    String
  targetId  String
  intimacy  Int      @default(0)
  level     String   @default("stranger")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, targetId])
}
